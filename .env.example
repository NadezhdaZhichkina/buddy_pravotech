# Buddy — AI-агент онбординга в Mattermost
# Скопируйте в .env и заполните значения

# LLM (OpenRouter)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Mattermost
MATTERMOST_BASE_URL=https://mchat.pravo.tech
MATTERMOST_BOT_TOKEN=mm-...
MATTERMOST_EXPERT_CHANNEL_ID=
MATTERMOST_MODERATOR_CHANNEL_ID=

# База данных (по умолчанию SQLite)
DATABASE_URL=sqlite:///./buddy.db

# Отладка (0 или 1)
DEBUG=0
